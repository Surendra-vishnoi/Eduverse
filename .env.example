# Security
JWT_SECRET=your_jwt_secret_here
SECRET_KEY=your_secret_key_here
FERNET_KEY=your_fernet_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie-based auth (recommended)
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_ACCESS_NAME=eduverse_access_token
AUTH_COOKIE_REFRESH_NAME=eduverse_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# CSRF (double-submit token)
CSRF_PROTECTION_ENABLED=true
CSRF_COOKIE_NAME=eduverse_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# Database
DATABASE_URL=postgresql+asyncpg://user:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://eduverse-4x8o.onrender.com/auth/callback

# File Storage
UPLOAD_DIR=./uploads

# Integrations
GROQ_API_KEY=gsk_your_groq_api_key
NOMIC_API_KEY=your-real-nomic-api-key-here

# Vector retrieval performance (pgvector)
VECTOR_EMBEDDING_DIM=768
PGVECTOR_ENABLE_FTS_GIN_INDEX=true
PGVECTOR_ENABLE_HNSW=true
PGVECTOR_AUTO_MIGRATE_VECTOR_DIMENSION=true
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64

# Frontend Redirect (OAuth callback handoff)
FRONTEND_URL=https://frontend-eduverse.vercel.app
FRONTEND_AUTH_CALLBACK_PATH=/auth/callback

# Application Settings
BACKEND_CORS_ORIGINS=["http://localhost:5173", "https://frontend-eduverse.vercel.app"]
RAG_ENABLE_RERANK=false
PDF_EXTRACT_IMAGES=false
DEBUG=false
